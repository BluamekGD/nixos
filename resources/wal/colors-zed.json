{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0a191990",
                "editor.background": "#0a191990",
                "editor.foreground": "#c1c5c5",
                "text": "#c1c5c5",
                "text.muted": "#c1c5c570",
                "text.ignored": "#c1c5c540",
                "text.placeholder": "#c1c5c550",
                "ignored": "#c1c5c530",
                "element.hover": "#c1c5c530",
                "ghost_element.hover": "#1671C930",
                "ghost_element.selected": "#1671C930",
                "ghost_element.active": "#1671C960",
                "border": "#0a1919",
                "editor.highlighted_line.background": "#1671C910",
                "editor.active_line.background": "#1671C910",
                "panel.background": "#0a191990",
                "title_bar.background": "#0a191990",
                "title_bar.inactive_background": "#0a191990",
                "status_bar.background": "#0a191990",
                "drop_target.background": "#0a191990",
                "elevated_surface.background": "#0a1919",
                "toolbar.background": "#0a191990",
                "tab_bar.background": "#0a191990",
                "tab.inactive_background": "#0a191990",
                "tab.active_background": "#1671C930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0a1919",
                "scrollbar.thumb.background": "#1671C9",
                "editor.gutter.background": "#0a191990",
                "terminal.background": "#0a191910",
                "terminal.foreground": "#c1c5c5",
                "terminal.dim_foreground": "#c1c5c5",
                "terminal.bright_foreground": "#c1c5c5",
                "terminal.ansi.black": "#0a1919",
                "terminal.ansi.red": "#1671C9",
                "terminal.ansi.green": "#5E97B6",
                "terminal.ansi.yellow": "#3388CE",
                "terminal.ansi.blue": "#599ED1",
                "terminal.ansi.magenta": "#8EA4B8",
                "terminal.ansi.cyan": "#98B5CF",
                "terminal.ansi.white": "#c1c5c5",
                "terminal.ansi.bright_black": "#596e6e",
                "terminal.ansi.bright_red": "#1671C9",
                "terminal.ansi.bright_green": "#5E97B6",
                "terminal.ansi.bright_yellow": "#3388CE",
                "terminal.ansi.bright_blue": "#599ED1",
                "terminal.ansi.bright_magenta": "#8EA4B8",
                "terminal.ansi.bright_cyan": "#98B5CF",
                "terminal.ansi.bright_white": "#c1c5c5",
                "modified": "#1671C9",
                "syntax": {
                    "attribute": {
                        "color": "#1671C9"
                    },
                    "boolean": {
                      "color": "#5E97B6"
                    },
                    "comment": {
                      "color": "#596e6e"
                    },
                    "comment.doc": {
                      "color": "#596e6e"
                    },
                    "constant": {
                      "color": "#5E97B6"
                    },
                    "function": {
                      "color": "#98B5CF"
                    },
                    "keyword": {
                      "color": "#599ED1"
                    },
                    "number": {
                      "color": "#8EA4B8"
                    },
                    "operator": {
                      "color": "#599ED1"
                    },
                    "string": {
                      "color": "#1671C9"
                    },
                    "variable": {
                      "color": "#5E97B6"
                    }
                },
                "players": [
                  {
                    "cursor": "#1671C9",
                    "background": "#0a1919",
                    "selection": "#1671C930"
                  }
                ]
            }
        }
    ]
}
